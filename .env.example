# ============================================================
# infonews.day — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs réelles
# NE JAMAIS committer le fichier .env sur GitHub
# ============================================================

# Clé API NewsAPI (https://newsapi.org — gratuit 100 req/jour)
NEWS_API_KEY=votre_cle_newsapi_ici

# Port du serveur Express
PORT=3000

# Environnement : development | production
NODE_ENV=development

# (Optionnel) URL de base pour les logs et redirections
BASE_URL=http://localhost:3000
