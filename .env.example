# ============================================================
# infonews.day v2 — Variables d'environnement
# Copier en .env — NE JAMAIS committer .env sur GitHub
# ============================================================

# --- OBLIGATOIRE ---
# NewsAPI (https://newsapi.org — gratuit : 100 req/jour)
NEWS_API_KEY=votre_cle_newsapi_ici

# --- SERVEUR ---
PORT=3000
NODE_ENV=development
BASE_URL=http://localhost:3000

# --- APIs GRATUITES SANS CLÉ (déjà intégrées, rien à configurer) ---
# Open-Meteo    → météo Barcelone     https://open-meteo.com
# CoinGecko     → crypto EUR          https://coingecko.com/api
# Yahoo Finance → indices boursiers   https://finance.yahoo.com
# Frankfurter   → devises EUR         https://frankfurter.app
# USGS          → séismes temps réel  https://earthquake.usgs.gov
# HackerNews    → tech/startup        https://hacker-news.firebaseio.com
# The Guardian  → RSS 6 rubriques     https://theguardian.com
# Al Jazeera    → RSS monde           https://aljazeera.com
# TechCrunch    → RSS tech/IA         https://techcrunch.com

# --- OPTIONNEL (plan gratuit disponible) ---
# The Guardian API officielle (500 req/jour) — meilleure que le RSS
# GUARDIAN_API_KEY=votre_cle_guardian_ici

# GNews API (100 req/jour, multilingue)
# GNEWS_API_KEY=votre_cle_gnews_ici
